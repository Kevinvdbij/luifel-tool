{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "luifel-tool",
  "version": "0.1.0",
  "identifier": "com.khr.luifeltool",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8081",
    "beforeDevCommand": "npx expo start",
    "beforeBuildCommand": "npx expo export"
  },
  "app": {
    "windows": [
      {
        "title": "Luifel Tool",
        "minWidth": 500,
        "minHeight": 800,
        "width": 500,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/khr.ico"
    ]
  }
}
